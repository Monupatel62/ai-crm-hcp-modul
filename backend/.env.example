# ─────────────────────────────────────────────────────────────
# AI CRM HCP Module — Backend Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Groq API key — get free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Assignment model
GROQ_MODEL=gemma2-9b-it

# Database — use SQLite locally or switch to PostgreSQL / MySQL for submission demo
DATABASE_URL=sqlite:///./crm.db
# Example PostgreSQL:
# DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/ai_crm
# Example MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_crm

# Allowed CORS origins (comma-separated)
# ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
